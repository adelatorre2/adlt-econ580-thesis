{
  // --- Writing ergonomics (Overleaf-like soft wrap) ---
  "editor.wordWrap": "bounded",
  "editor.wordWrapColumn": 100,
  "editor.wrappingIndent": "same",
  "editor.rulers": [80, 100],
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "selection",
  "editor.unicodeHighlight.ambiguousCharacters": false,

  // --- LaTeX Workshop (stable, minimal friction) ---
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.outDir": "./out",
  "latex-workshop.synctex.afterBuild.enabled": true,
  "latex-workshop.view.pdf.internal.synctex.keybinding": "double-click",
  "latex-workshop.message.log.show": false,
  "latex-workshop.message.warning.show": true,
  "latex-workshop.latex.clean.fileTypes": [
    "*.aux",
    "*.bbl",
    "*.bcf",
    "*.blg",
    "*.fdb_latexmk",
    "*.fls",
    "*.log",
    "*.out",
    "*.run.xml",
    "*.toc"
  ],

  // Tools: pdfLaTeX + Biber (for biblatex)
  "latex-workshop.latex.tools": [
    {
      "name": "pdflatex",
      "command": "/usr/local/texlive/2024/bin/universal-darwin/pdflatex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "%DOC%"
      ]
    },
    {
      "name": "biber",
      "command": "/usr/local/texlive/2024/bin/universal-darwin/biber",
      "args": [
        "%DOCFILE%"
      ]
    },
    {
      "name": "latexmk",
      "command": "latexmk",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-pdf",
        "%DOC%"
      ]
    }
  ],

  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk 🔁 (recommended)",
      "tools": ["latexmk"]
    },
    {
      "name": "pdflatex → biber → pdflatex ×2",
      "tools": ["pdflatex", "biber", "pdflatex", "pdflatex"]
    }
  ],

  // Default to latexmk so biber runs automatically when needed
  "latex-workshop.latex.recipe.default": "latexmk 🔁 (recommended)",

  // --- Spell + grammar for LaTeX (LTeX) ---
  "ltex.language": "en-US",
  "ltex.enabled": ["latex", "bibtex"],
  "ltex.diagnosticSeverity": "information",
  "ltex.latex.commands": {
    "\\cite{}": "ignore",
    "\\citep{}": "ignore",
    "\\citet{}": "ignore",
    "\\parencite{}": "ignore",
    "\\textcite{}": "ignore",
    "\\autocite{}": "ignore"
  },

  // --- Quality-of-life ---
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true
  // --- Python environment (lock project to local .venv) ---
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": true
}
