@article{alpertSupplySideDrugPolicy2018a,
  title = {Supply-{{Side Drug Policy}} in the {{Presence}} of {{Substitutes}}: {{Evidence}} from the {{Introduction}} of {{Abuse-Deterrent Opioids}}},
  shorttitle = {Supply-{{Side Drug Policy}} in the {{Presence}} of {{Substitutes}}},
  author = {Alpert, Abby and Powell, David and Pacula, Rosalie Liccardo},
  year = 2018,
  month = nov,
  journal = {American Economic Journal: Economic Policy},
  volume = {10},
  number = {4},
  pages = {1--35},
  issn = {1945-7731, 1945-774X},
  doi = {10.1257/pol.20170082},
  urldate = {2026-03-10},
  abstract = {Overdose deaths from prescription opioid pain relievers nearly quadrupled between 1999 and 2010. We study the consequences of one of the largest supply disruptions to date to abusable opioids---the introduction of an abuse-deterrent version of OxyContin in 2010. Supply-side interventions that limit access to opioids may have the unintended consequence of increasing use of substitute drugs, including heroin. Exploiting cross-state variation in OxyContin exposure, we find that states with the highest initial rates of OxyContin misuse experienced the largest increases in heroin deaths. Our results imply that the recent heroin epidemic is largely due to the reformulation of OxyContin. (JEL I12, I18)},
  langid = {english},
  keywords = {2010,abuse-deterrent oxycontin,increased use of substitute drugs,opioids,substitutes,supply-side drug policy},
  file = {/Users/alexdelatorre/Zotero/storage/MCXQ3CWS/Alpert et al. - 2018 - Supply-Side Drug Policy in the Presence of Substitutes Evidence from the Introduction of Abuse-Dete.pdf}
}

