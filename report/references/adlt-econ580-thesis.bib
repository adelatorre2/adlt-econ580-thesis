@article{olsonFirmCharacteristicsSpeed1997,
  title = {Firm {{Characteristics}} and the {{Speed}} of {{FDA Approval}}},
  author = {Olson, Mary K.},
  year = 1997,
  journal = {Journal of Economics \& Management Strategy},
  volume = {6},
  number = {1},
  pages = {377--401},
  issn = {1530-9134},
  doi = {10.1111/j.1430-9134.1997.00377.x},
  urldate = {2026-03-08},
  abstract = {This paper empirically examines the effect of firm-specific characteristics on the length of time required by the Food and Drug Administration (FDA) to review and approve new-drug applications between 1990 and 1992. The approach treats regulatory decisions as endogenous and explains the variation in regulatory behavior as a function of differences that exist between firms and drugs. Results show that, controlling for drug-specific characteristics, regulators respond to firm-specific characteristics when evaluating new drug applications. For instance, firms that are less diversified and more R\&D-inten-sive receive shorter review times for their new-drug applications than more diversified and less R\&D-intensive firms. The reason is that most firm characteristics signal information to reviewers about either firm reputation or application quality. This information reduces reviewers' uncertainty about approving a dangerous or ineffective drug and leads to faster review times. The results suggest that regulators respond to the heterogeneities among firms in the pharmaceutical market in systematic ways.},
  langid = {english},
  note = {\section{Paper: Olson (1997) -- Firm Characteristics and the Speed of FDA Approval}

\subsection{1. Research Question:}

\par
Do firm-level characteristics influence the speed of FDA approval for new drug applications (NDAs)? Specifically, does the FDA review process vary systematically with characteristics such as firm size, R\&D intensity, diversification, or experience, rather than depending only on drug characteristics?
\par
\subsubsection{2. Data:}

\begin{itemize}

\item Unit of observation: New Drug Applications (NDAs)
\item  Time period: Early 1990s (around 1990--1992)
\item Sources: FDA approval data combined with firm-level data
\item 
\par
Key variables:
\par
\begin{itemize}

\item Outcome: FDA review time (submission {$\rightarrow$} approval)
\item Drug controls: therapeutic category, novelty, importance
\item Firm characteristics: R\&D intensity, firm size, diversification, experience

\end{itemize}

\end{itemize}

\subsubsection{3. Identification:}

\par
Cross-sectional regression analysis explaining variation in FDA review time.
\par
ReviewTime\_i = f(DrugCharacteristics\_i, FirmCharacteristics\_i)
\par
\textbf{Strategy:}
\par
Control for observable drug characteristics and test whether firm characteristics still predict approval speed. Identification relies on cross-firm variation rather than a causal policy shock (no IV or DiD).
\par
\subsubsection{4. Main Results:}

\begin{itemize}

\item Firms with higher R\&D intensity tend to receive faster FDA approvals.
\item Less diversified (more pharma-focused) firms receive faster approvals.
\item Firm characteristics act as signals of credibility and expected drug quality.
\item FDA review behavior appears responsive to firm reputation and expertise.

\end{itemize}

\subsubsection{5. Limitations:}

\begin{itemize}

\item Identification is correlational; potential omitted variable bias.
\item Short time window and small sample of NDAs.
\item Predates major regulatory reforms such as PDUFA and modern accelerated approval programs.
\item Does not study downstream effects (safety, misuse, diversion, or market outcomes).

\end{itemize}

\subsubsection{6. Connection to My Project:}

\par
This paper establishes that FDA approval speed is not random and depends partly on firm characteristics. For my project studying whether faster regulatory approval increases downstream diversion risk in U.S. drug markets, this suggests approval speed may be endogenous. Firm traits may influence both regulatory speed and eventual market supply, meaning empirical designs must account for the determinants of approval timing when estimating downstream effects.
\par
Tags:
\par
FDA
\par
approval speed
\par
regulatory behavior
\par
firm characteristics
\par
pharmaceutical industry
\par
regulatory economics
\par
BACKGROUND},
  file = {/Users/alexdelatorre/Zotero/storage/II5UNC2E/Olson - 1997 - Firm Characteristics and the Speed of FDA Approval.pdf;/Users/alexdelatorre/Zotero/storage/CNBT9DPU/j.1430-9134.1997.00377.html}
}

