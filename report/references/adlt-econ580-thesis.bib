@article{carpenterDrugreviewDeadlinesSafety2008,
  title = {Drug-Review Deadlines and Safety Problems},
  author = {Carpenter, Daniel and Zucker, Evan James and Avorn, Jerry},
  year = 2008,
  month = mar,
  journal = {The New England Journal of Medicine},
  volume = {358},
  number = {13},
  pages = {1354--1361},
  issn = {1533-4406},
  doi = {10.1056/NEJMsa0706341},
  abstract = {BACKGROUND: The Prescription Drug User Fee Act (PDUFA) imposes deadlines for the completion of drug reviews by the Food and Drug Administration (FDA). Critics have suggested that these deadlines may result in rushed approvals and the emergence of unanticipated safety problems once a product is in clinical use. METHODS: We assessed the association between the PDUFA deadlines and the timing of FDA drug approval by constructing dynamic Cox proportional-hazards models of review times for all new molecular entities approved between 1950 and 2005. To determine whether the deadlines were associated with postmarketing safety problems, we focused on drugs submitted since January 1993, when the deadlines were first imposed. We used exact logistic regression to determine whether drugs approved immediately before the deadlines were associated with a higher rate of postmarketing safety problems (e.g., withdrawals and black-box warnings) than drugs approved at other times. RESULTS: Initiation of the PDUFA requirements concentrated the number of approval decisions made in the weeks immediately preceding the deadlines. As compared with drugs approved at other times, drugs approved in the 2 months before their PDUFA deadlines were more likely to be withdrawn for safety reasons (odds ratio, 5.5; 95\% confidence interval [CI], 1.3 to 27.8), more likely to carry a subsequent black-box warning (odds ratio, 4.4; 95\% CI, 1.2 to 20.5), and more likely to have one or more dosage forms voluntarily discontinued by the manufacturer (odds ratio, 3.3; 95\% CI, 1.5 to 7.5). CONCLUSIONS: PDUFA deadlines have appreciably changed the approval decisions of the FDA. Once medications are in clinical use, the discovery of safety problems is more likely for drugs approved immediately before a deadline than for those approved at other times.},
  langid = {english},
  pmid = {18367738},
  keywords = {Drug and Narcotic Control,Drug Approval,Drug Industry,Drug Labeling,Drug-Related Side Effects and Adverse Reactions,Government Regulation,Product Surveillance Postmarketing,Time Factors,United States,United States Food and Drug Administration},
  note = {Paper: Carpenter, Daniel; Zucker, Evan; Avorn, Jerry (2008) --- "Drug-Review Deadlines and Safety Problems" --- New England Journal of Medicine
\par
1. Research Question:
\par
Do FDA drug-review deadlines introduced under the Prescription Drug User Fee Act (PDUFA) lead to an increased risk of post-marketing safety problems for newly approved drugs?
\par
2. Data:
\par
The authors compile a dataset of all FDA-approved new molecular entities (NMEs) from 1950--2004. The main analysis focuses on drugs submitted after 1993 (when PDUFA deadlines began). The data include:
\par
- FDA approval timing
\par
- Review cycle length
\par
- Postmarketing safety outcomes
\par
- Drug characteristics and therapeutic indications
\par
Post-approval safety outcomes are measured using:
\par
- Safety-based market withdrawals
\par
- Addition of black-box warnings
\par
- Discontinuation of dosage forms
\par
Sources include Drugs@FDA, Pharmaprojects, Scrip reports, and other regulatory datasets.
\par
3. Identification:
\par
The key identification strategy exploits the timing of approvals relative to PDUFA review deadlines. The authors compare drugs approved in the final two months before the regulatory deadline with drugs approved:
\par
- earlier in the review cycle
\par
- after the deadline
\par
- at other times in the review process
\par
Methods include:
\par
- Cox proportional-hazards models to study approval timing
\par
- Exact logistic regression to estimate the probability of postmarketing safety events
\par
The strategy tests whether drugs approved just before regulatory deadlines exhibit higher safety risks.
\par
4. Main Results:
\par
The introduction of PDUFA deadlines significantly changed the timing of FDA approval decisions, concentrating approvals in the two months immediately before the deadline. (p. 1359)
\par
Drugs approved within two months before the deadline are significantly more likely to experience postmarketing safety problems:
\par
- Safety-based withdrawal: odds ratio {$\approx$} 5.5
\par
- Black-box warning added later: odds ratio {$\approx$} 4.4
\par
- Dosage-form discontinuation: odds ratio {$\approx$} 3.3
\par
These safety risks remain elevated when comparing just-before-deadline approvals to both early approvals and approvals just after the deadline.
\par
Importantly, the authors find that the increased risk is associated with the deadline itself rather than with shorter review times per se.
\par
5. Limitations:
\par
The study is observational, so approval timing is not randomly assigned. Unobserved factors could influence both approval timing and safety outcomes.
\par
Measures of safety outcomes (withdrawals, warnings) capture only detected postmarket problems and may underestimate total safety risks.
\par
The paper does not perform a full cost-benefit analysis of faster approvals versus safety risks.
\par
Other changes in drug development, regulatory practice, and monitoring over time could also affect safety outcomes.
\par
6. How this connects to MY project:
\par
This paper provides direct evidence that regulatory mechanisms designed to speed drug approval (PDUFA deadlines) can affect downstream safety outcomes. It demonstrates that institutional incentives within the FDA approval process can change approval timing and potentially increase the risk of postmarketing problems.
\par
For my project on "regulatory speed and diversion risk in U.S. drug markets," this paper is important because it establishes a causal pathway from regulatory acceleration mechanisms to downstream unintended consequences. While the authors focus on safety risks (withdrawals and warnings), my research extends this logic to examine whether accelerated approval pathways may also increase diversion or misuse risks once drugs enter broader circulation.
\par
Relevant Tags:
\par
MUST\_CITE
\par
CORE\_LIT
\par
PDUFA
\par
REGULATION
\par
APPROVAL\_SPEED
\par
SAFETY\_OUTCOMES
\par
FDA\_POLICY
\par
IDENTIFICATION\_IDEA},
  file = {/Users/alexdelatorre/Zotero/storage/NQRASGJJ/Carpenter et al. - 2008 - Drug-review deadlines and safety problems.pdf}
}

