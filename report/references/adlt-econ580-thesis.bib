  file = {/Users/alexdelatorre/Zotero/storage/ALVEFRRV/Olson - 2008 - The risk we bear The effects of review speed and industry user fees on new drug safety.pdf;/Users/alexdelatorre/Zotero/storage/NPJI5GI6/S0167629607000732.html}
}

