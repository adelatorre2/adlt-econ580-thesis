@article{afrihyiaFDADrugRegulations,
  title = {{{FDA Drug Regulations}} and {{Pharmaceutical Innovation}}: {{Balancing Expedited Approval}} with {{Safety}} and {{Market Accessibility}}.},
  author = {Afrihyia, Erica and Forkuo, Adelaide Yeboah and Chianumba, Ernest Chinonso and Yetunde, Ashiata and Omotayo, Olufunke},
  abstract = {The regulation of pharmaceuticals by the U.S. Food and Drug Administration (FDA) plays a crucial role in balancing the need for expedited drug approval, patient safety, and market accessibility. This paper examines the impact of FDA drug regulations on pharmaceutical innovation, assessing how regulatory frameworks influence the speed at which new drugs reach the market while ensuring public health protections. The study explores key regulatory pathways, including the Fast Track, Breakthrough Therapy, Accelerated Approval, and Priority Review designations, which facilitate faster access to novel treatments.},
  langid = {english},
  keywords = {expedited approval,FDA,Speed vs Safety tradeoff},
  file = {/Users/alexdelatorre/Zotero/storage/DBMZW9BT/Afrihyia et al. - FDA Drug Regulations and Pharmaceutical Innovation Balancing Expedited Approval with Safety and Mar.pdf}
}

