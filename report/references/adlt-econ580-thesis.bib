@article{olsonFirmCharacteristicsSpeed1997,
  title = {Firm {{Characteristics}} and the {{Speed}} of {{FDA Approval}}},
  author = {Olson, Mary K.},
  year = 1997,
  journal = {Journal of Economics \& Management Strategy},
  volume = {6},
  number = {1},
  pages = {377--401},
  issn = {1530-9134},
  doi = {10.1111/j.1430-9134.1997.00377.x},
  urldate = {2026-03-08},
  abstract = {This paper empirically examines the effect of firm-specific characteristics on the length of time required by the Food and Drug Administration (FDA) to review and approve new-drug applications between 1990 and 1992. The approach treats regulatory decisions as endogenous and explains the variation in regulatory behavior as a function of differences that exist between firms and drugs. Results show that, controlling for drug-specific characteristics, regulators respond to firm-specific characteristics when evaluating new drug applications. For instance, firms that are less diversified and more R\&D-inten-sive receive shorter review times for their new-drug applications than more diversified and less R\&D-intensive firms. The reason is that most firm characteristics signal information to reviewers about either firm reputation or application quality. This information reduces reviewers' uncertainty about approving a dangerous or ineffective drug and leads to faster review times. The results suggest that regulators respond to the heterogeneities among firms in the pharmaceutical market in systematic ways.},
  langid = {english},
  note = {\section{Paper: Olson (1997) -- Firm Characteristics and the Speed of FDA Approval}

\subsection{1. Research Question:}

\par
Do firm-level characteristics influence the speed of FDA approval for new drug applications (NDAs)? Specifically, does the FDA review process vary systematically with characteristics such as firm size, R\&D intensity, diversification, or experience, rather than depending only on drug characteristics?
\par
\subsubsection{2. Data:}

\begin{itemize}

\item Unit of observation: New Drug Applications (NDAs)
\item  Time period: Early 1990s (around 1990--1992)
\item Sources: FDA approval data combined with firm-level data
\item 
\par
Key variables:
\par
\begin{itemize}

\item Outcome: FDA review time (submission {$\rightarrow$} approval)
\item Drug controls: therapeutic category, novelty, importance
\item Firm characteristics: R\&D intensity, firm size, diversification, experience

\end{itemize}

\end{itemize}

\subsubsection{3. Identification:}

\par
Cross-sectional regression analysis explaining variation in FDA review time.
\par
ReviewTime\_i = f(DrugCharacteristics\_i, FirmCharacteristics\_i)
\par
\textbf{Strategy:}
\par
Control for observable drug characteristics and test whether firm characteristics still predict approval speed. Identification relies on cross-firm variation rather than a causal policy shock (no IV or DiD).
\par
\subsubsection{4. Main Results:}

\begin{itemize}

\item Firms with higher R\&D intensity tend to receive faster FDA approvals.
\item Less diversified (more pharma-focused) firms receive faster approvals.
\item Firm characteristics act as signals of credibility and expected drug quality.
\item FDA review behavior appears responsive to firm reputation and expertise.

\end{itemize}

\subsubsection{5. Limitations:}

\begin{itemize}

\item Identification is correlational; potential omitted variable bias.
\item Short time window and small sample of NDAs.
\item Predates major regulatory reforms such as PDUFA and modern accelerated approval programs.
\item Does not study downstream effects (safety, misuse, diversion, or market outcomes).

\end{itemize}

\subsubsection{6. Connection to My Project:}

\par
This paper establishes that FDA approval speed is not random and depends partly on firm characteristics. For my project studying whether faster regulatory approval increases downstream diversion risk in U.S. drug markets, this suggests approval speed may be endogenous. Firm traits may influence both regulatory speed and eventual market supply, meaning empirical designs must account for the determinants of approval timing when estimating downstream effects.
\par
Tags:
\par
FDA
\par
approval speed
\par
regulatory behavior
\par
firm characteristics
\par
pharmaceutical industry
\par
regulatory economics
\par
BACKGROUND},
  file = {/Users/alexdelatorre/Zotero/storage/II5UNC2E/Olson - 1997 - Firm Characteristics and the Speed of FDA Approval.pdf;/Users/alexdelatorre/Zotero/storage/CNBT9DPU/j.1430-9134.1997.00377.html}
}

@article{olsonPDUFAInitialUS2009,
  title = {{{PDUFA}} and {{Initial U}}.{{S}}. {{Drug Launches}}},
  author = {Olson, Mary},
  year = 2009,
  month = jan,
  journal = {Michigan Telecommunications \& Technology Law Review},
  volume = {15},
  number = {2},
  pages = {393--416},
  issn = {1528-8625},
  keywords = {FDA,PDUFA},
  note = {Paper: "PDUFA and Initial U.S. Drug Launches"
\par
RELEVANCE TO PROJECT:
\par
This paper studies how the Prescription Drug User Fee Act (PDUFA) affected the timing and behavior of pharmaceutical firms launching drugs in the U.S. market. Because PDUFA was designed to accelerate FDA review times, the paper provides evidence on how regulatory speed changes firm behavior and drug supply timing. This is directly relevant to a project examining whether faster regulatory approval can create downstream externalities such as drug diversion.
\par
1. Research Question:
\par
Did the Prescription Drug User Fee Act (PDUFA) --- which increased FDA resources and accelerated review timelines --- change the timing and likelihood of pharmaceutical firms launching new drugs in the United States? More broadly, the paper asks whether faster regulatory approval alters firms' global launch strategies and incentives to bring drugs to the U.S. market sooner.
\par
2. Data:
\par
The paper uses data on new pharmaceutical product launches across countries, including:
\par
- Global drug launch data
\par
- FDA approval data
\par
- Information on timing of drug introduction across different countries
\par
- Drug characteristics (therapeutic class, innovation status)
\par
- Firm characteristics
\par
The key variable of interest is the timing of initial drug launches relative to regulatory changes introduced by PDUFA.
\par
3. Identification:
\par
The identification strategy exploits the introduction of PDUFA as a policy shock that accelerated FDA review times. The authors compare launch behavior before and after PDUFA implementation and analyze whether the U.S. became a more attractive early launch market relative to other countries once approval times shortened.
\par
This effectively uses a policy change affecting regulatory speed to study how firms adjust launch timing decisions.
\par
4. Main Results:
\par
The paper finds that PDUFA significantly altered pharmaceutical firms' launch behavior.
\par
Key findings include:
\par
- FDA review times declined after PDUFA due to increased resources and review deadlines.
\par
- Firms became more likely to launch drugs earlier in the United States relative to other markets.
\par
- The U.S. increasingly became the first launch market for many drugs after the reform.
\par
- Faster regulatory approval therefore shifted global launch strategies and accelerated the availability of drugs in the U.S.
\par
5. Limitations:
\par
The paper focuses on firm launch behavior rather than downstream outcomes. It does not study:
\par
- prescribing patterns,
\par
- drug misuse,
\par
- diversion into illicit markets,
\par
- or post-market safety outcomes.
\par
As a result, the paper cannot assess whether faster approval generates unintended consequences such as misuse or diversion.
\par
Additionally, the study focuses on launch timing rather than long-run drug supply or consumption patterns.
\par
6. How this connects to MY project:
\par
This paper provides causal evidence that regulatory acceleration policies such as PDUFA change pharmaceutical firm behavior and increase the speed at which drugs enter the U.S. market.
\par
For a project studying whether faster regulatory approval increases diversion risk, this paper helps establish the upstream mechanism: regulatory reforms that accelerate FDA review lead firms to introduce drugs earlier and potentially increase legal pharmaceutical supply. If faster approvals expand the availability of certain drugs --- especially those with abuse potential --- they may create opportunities for diversion into illicit markets.
\par
Thus, this paper contributes to the "regulatory speed {$\rightarrow$} pharmaceutical supply" link that precedes the diversion mechanisms the thesis aims to study.`},
  file = {/Users/alexdelatorre/Zotero/storage/APAQI8CQ/Olson - 2009 - PDUFA and Initial U.S. Drug Launches.pdf;/Users/alexdelatorre/Zotero/storage/2QW4UNK6/3.html}
}

@article{olsonRiskWeBear2008,
  title = {The Risk We Bear: {{The}} Effects of Review Speed and Industry User Fees on New Drug Safety},
  shorttitle = {The Risk We Bear},
  author = {Olson, Mary K.},
  year = 2008,
  month = mar,
  journal = {Journal of Health Economics},
  volume = {27},
  number = {2},
  pages = {175--200},
  issn = {0167-6296},
  doi = {10.1016/j.jhealeco.2007.10.007},
  urldate = {2026-03-10},
  abstract = {Drug review speed has increased substantially in the 1990s, largely due to industry-funded user fees. Following several drug withdrawals, however, new questions have emerged about the effects of this change on drug safety. This article examines the impact of review speed and user fees on counts of serious adverse reactions among drugs approved in 1990--2001. The analysis controls for the influence of drug utilization, patient conditions, drug novelty, black box warnings, foreign drug launch, US launch lags, patient age, and gender on drug reactions. Results show that drugs receiving faster reviews are associated with increased counts of serious adverse drug reactions. Other results show that novel drugs, drugs with black box warnings, drugs first launched abroad, and drugs with shorter US launch lags also have increased adverse drug reactions. Although any increase in risks must be weighed against benefits, the results show a trade-off between review speed and drug safety.},
