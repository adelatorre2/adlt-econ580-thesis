@article{kaitinPharmaceuticalInnovation21st2011,
  title = {Pharmaceutical Innovation in the 21st Century: New Drug Approvals in the First Decade, 2000-2009},
  shorttitle = {Pharmaceutical Innovation in the 21st Century},
  author = {Kaitin, K. I. and DiMasi, J. A.},
  year = 2011,
  month = feb,
  journal = {Clinical Pharmacology and Therapeutics},
  volume = {89},
  number = {2},
  pages = {183--188},
  issn = {1532-6535},
  doi = {10.1038/clpt.2010.286},
  abstract = {The first decade of the 21st century was a challenging period for the pharma sector and could prove to be a turning point in the evolution of the industry. We examine drug development performance metrics for new product approvals during 2000-2009 and compare them with those of the prior two decades. The results indicate that, whereas total approvals are currently at a 25-year low, the percentage of priority products is nearly 50\% of the total--a 30-year high. Following enactment of the Prescription Drug Use Fee Act of 1992 (PDUFA), the mean duration of the approval phases of drug development declined by more than 1 year over the 30-year period--to a low of 1.2 years in 2005-2009--whereas the duration of the clinical phases increased. The longer clinical phases were due, in part, to a greater number of approved central nervous system (CNS) and antineoplastic agents, two therapeutic classes with relatively long average development times (8.1 and 6.9 years, respectively). The results provide the underpinnings of a fundamental shift in the structure of the research-based industry.},
  langid = {english},
  pmid = {21191382},
  keywords = {2000,2000s,2009,Drug Approval,drug development,Drug Discovery,Drug Industry,early 2000s,innovation,Legislation Drug,Orphan Drug Production,PDUFA,shift in the structure of the research-based industry,Time Factors,United States,United States Food and Drug Administration}
}

@article{kimMustaccessPrescriptionDrug2021,
  title = {Must-Access Prescription Drug Monitoring Programs and the Opioid Overdose Epidemic: {{The}} Unintended Consequences},
  shorttitle = {Must-Access Prescription Drug Monitoring Programs and the Opioid Overdose Epidemic},
  author = {Kim, Bokyung},
  year = 2021,
  month = jan,
  journal = {Journal of Health Economics},
  volume = {75},
  pages = {102408},
  issn = {0167-6296},
  doi = {10.1016/j.jhealeco.2020.102408},
  urldate = {2026-03-10},
  abstract = {Although supply-side drug policies that limit access to legal opioids have reduced prescription opioid abuse, growing evidence shows that these policies have had the unintended consequence of increasing use of illegal opioids, including heroin. I add to this literature by studying the consequences of must-access prescription drug monitoring programs (PDMPs), which legally require providers to access a state-level database with a patient's prescription history before prescribing controlled substances under certain circumstances. Using a difference-in-differences specification, I find strong evidence that must-access PDMPs have increased heroin death rates. My estimates indicate that two years after implementation, must-access PDMPs were associated with 0.9 more heroin deaths per 100,000 in a half-year period, relative to control states. My results suggest that even if must-access PDMPs reduce prescription opioid deaths, the decrease is offset by a large increase in illegal opioid deaths.},
  keywords = {Heroin,increased illegal use of opiods,must-access PDMP,Must-access PDMP,must-access prescription drug monitoring programs,Opioid,Opioid epidemic,Opioid overdose,PDMP,Prescription drug monitoring program,prescription drug monitoring programs},
  file = {/Users/alexdelatorre/Zotero/storage/RAZGM4CL/Kim - 2021 - Must-access prescription drug monitoring programs and the opioid overdose epidemic The unintended c.pdf;/Users/alexdelatorre/Zotero/storage/N6EE6FW6/S0167629620310547.html}
}

